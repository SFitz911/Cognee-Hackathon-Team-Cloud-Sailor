# Secrets
.env
.env.*
!.env.example

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.cognee_system/
cognee_data/

# Large generated media — clips/audio are regenerated, not version-controlled.
# (Stills in media/images, including the poster, ARE committed so the app works on clone.)
media/clips/*
media/posters/*
!media/**/.gitkeep
# The founder video pools ARE committed so the cameo works on the cloud deploy.
!media/clips/founder_talk_*.mp4
!media/clips/founder_say_*.mp4
!media/clips/founder_say_manifest.json
# Story videos for the narrative pages ARE committed.
!media/clips/winning_dogshow.mp4
!media/clips/reunion_code.mp4
!media/clips/code_to_gym.mp4
!media/clips/founder_data.mp4
# Chow cameo audio IS committed so the cameo works on the cloud deploy.
!media/audio/chow_*.mp3
!media/audio/chow_manifest.json

# Enrolled faces (PII) and DeepFace caches — never commit
media/faces/
*.pkl
