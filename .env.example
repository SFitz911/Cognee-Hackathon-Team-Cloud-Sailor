# Wolfpack Recall — environment configuration
# Copy to `.env` and fill in. Never commit the real .env (it is gitignored).

# --- Cognee Cloud (memory layer) ---
# Either the COGWIT_* names or the COGNEE_* aliases work; the client reads both.
COGWIT_API_BASE=https://<your-tenant>.aws.cognee.ai
COGWIT_API_KEY=<your-cognee-api-key>
COGNEE_BASE_URL=https://<your-tenant>.aws.cognee.ai
COGNEE_API_KEY=<your-cognee-api-key>

# Dataset (memory "topic") the app reads/writes. Isolates each case.
COGNEE_DATASET=pinky_serbia

# --- Anthropic (the four personalities) ---
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# --- OpenAI (optional: poster generation via scripts/gen_poster.py) ---
# Not required — scripts/gen_poster_hf.py generates posters via a free HF Space.
OPENAI_API_KEY=<optional-openai-api-key>
